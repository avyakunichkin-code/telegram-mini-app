# Скопируйте в .env и заполните. Файл .env не коммитится.

DATABASE_URL=postgresql://user:pass@host/dbname
SECRET_KEY=change-me

# Admin Watchtower (MVP 1.2)
ADMIN_USER_IDS=1
OPS_TELEGRAM_BOT_TOKEN=
OPS_TELEGRAM_CHAT_ID=

