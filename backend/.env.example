# Скопируйте в .env и заполните. Файл .env не коммитится.

DATABASE_URL=postgresql://user:pass@host/dbname
SECRET_KEY=change-me

# Admin Watchtower (MVP 1.2)
ADMIN_USER_IDS=1
OPS_TELEGRAM_BOT_TOKEN=
OPS_TELEGRAM_CHAT_ID=

# Публичный URL Mini App (HashRouter: завершайте на /#)
# Pre-Alpha / Alpha: свой домен приложения
# PUBLIC_APP_URL=https://app.example.com/#
# ADMIN_WEB_BASE_URL=https://app.example.com/#

# CORS: явные origins (через запятую). Origin из PUBLIC_APP_URL добавляется автоматически.
# CORS_ALLOW_ORIGINS=https://app.example.com

# Regex для *.github.io (старый стенд). Отключить: CORS_ALLOW_ORIGIN_REGEX=none
# CORS_ALLOW_ORIGIN_REGEX=^https://[\w-]+\.github\.io$
