# Скопируйте в .env.local для локальной разработки (файл не коммитится).

# Базовый путь статики. Для своего домена в корне: VITE_BASE_PATH=/
# GitHub Pages (текущий): /telegram-mini-app/
VITE_BASE_PATH=/telegram-mini-app/

# API (prod/staging). Локально dev-сервер проксирует /api → этот хост.
VITE_API_BASE_URL=https://telegram-mini-app-zwfs.onrender.com

# --- Пример после подключения домена (сборка в CI или .env.production.local) ---
# VITE_BASE_PATH=/
# VITE_API_BASE_URL=https://api.example.com
